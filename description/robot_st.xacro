<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

    <xacro:include filename="robot_inertia.xacro" />
    <xacro:include filename="robot_rviz_colors.xacro" />

    <!-- ========================================= -->
    <!-- Robot parameters - change here -->
    <!-- ========================================= -->
    <!-- full robot mass approx 750g -->
    <!-- Main body -->
    <xacro:property name="body_length" value="0.23" />    <!-- (X) -->
    <xacro:property name="body_width" value="0.13" />  <!-- (Y) -->
    <xacro:property name="body_height" value="0.12" />    <!-- (Z) -->
    <xacro:property name="body_mass" value="0.65" />
    
    <!-- Axes -->
    <xacro:property name="axis_radius" value="0.005" />
    <xacro:property name="axis_mass" value="0.02" />
    
    <!-- Wheels -->
    <xacro:property name="wheel_radius" value="0.03" />
    <xacro:property name="wheel_width" value="0.03" />
    <xacro:property name="wheel_mass" value="0.03" />
    
    <!-- camera (relative to other dimensions) -->
    <xacro:property name="camera_size_x" value="0.04" />
    <xacro:property name="camera_size_y" value="0.03" />  <!-- half main body width -->
    <xacro:property name="camera_size_z" value="0.04" />
    <xacro:property name="camera_mass" value="0.01" />
    <xacro:property name="camera_pan_min" value="${-pi/2}" />   <!-- -90° -->
    <xacro:property name="camera_pan_max" value="${pi/2}" />    <!-- +90° -->
    
    <!-- Ультразвуковой датчик (спереди) -->
    <xacro:property name="us_length" value="0.015" />  <!-- depth (forward) -->
    <xacro:property name="us_width" value="0.045" />   <!-- width -->
    <xacro:property name="us_height" value="0.02" />  <!-- height --> 
    <xacro:property name="us_mass" value="0.005" />
    <xacro:property name="servo_size" value="0.03" />
    
    <!-- Distance from center  (wheel base / 2) -->
    <xacro:property name="wheel_base_half" value="${body_length * 0.35}" />  <!-- 35% from length -->
    <xacro:property name="axis_height" value="${wheel_radius + 0.03}" />

    <!-- Base link, needed due to some limitations in rviz2 -->

    <link name="base_link"/>

    <joint name="base_to_body" type="fixed">
        <parent link="base_link"/>
        <child link="robot_body"/>
        <origin xyz="0 0 0" rpy="0 0 ${pi}"/>
    </joint>

    <!-- robot's body -->
    <link name="robot_body">
        <visual>
            <geometry>
                <box size="${body_length} ${body_width} ${body_height}"/>
            </geometry>
            <material name="yellow"/>
        </visual>
        <collision>
            <geometry>
                <box size="${body_length} ${body_width} ${body_height}"/>
            </geometry>
        </collision>
        <xacro:inertial_box mass="${body_mass}" x="${body_length}" y="${body_width}" z="${body_height}">
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </xacro:inertial_box>
    </link>
    <gazebo reference="robot_body">
        <material>Gazebo/Yellow</material>
    </gazebo>

    <!-- ========================================= -->
    <!-- Ultrasonic sensor (front) -->
    <!-- ========================================= -->
    
    <link name="ultrasonic_sensor">
        <visual>
            <geometry>
                <box size="${us_length} ${us_width} ${us_height}"/>
            </geometry>
            <material name="blue"/>
        </visual>
        <collision>
            <geometry>
                <box size="${us_length} ${us_width} ${us_height}"/>
            </geometry>
        </collision>
        <xacro:inertial_box mass="${us_mass}" x="${us_length}" y="${us_width}" z="${us_height}">
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </xacro:inertial_box>
    </link>
    

    <joint name="ultrasonic_joint" type="fixed">
        <parent link="robot_body"/>
        <child link="ultrasonic_sensor"/>
        <origin xyz="${body_length/2 + us_length/2} 0 0" rpy="0 0 0"/>
    </joint>

    <!-- ========================================= -->
    <!-- Axes (front and rear) -->
    <!-- ========================================= -->
    
    <!-- Axes -->
    <xacro:macro name="wheel_axis" params="name">
        <link name="${name}_axis">
            <visual>
                <geometry><cylinder radius="${axis_radius}" length="${body_width + wheel_width}"/></geometry>
                <material name="black"/>
            </visual>
            <collision>
                <geometry><cylinder radius="${axis_radius}" length="${body_width + wheel_width}"/></geometry>
            </collision>
            <xacro:inertial_cylinder mass="${axis_mass}" length="${body_width + wheel_width}" radius="${axis_radius}">
                <origin xyz="0 0 0" rpy="0 0 0"/>
            </xacro:inertial_cylinder>
        </link>
        <gazebo reference="${name}_axis">
            <material>Gazebo/Black</material>
        </gazebo>
    </xacro:macro>

    <!-- create axes -->
    <xacro:wheel_axis name="front"/>
    <xacro:wheel_axis name="rear"/>

    <!-- axes and body joints -->
    <joint name="axis_joint_front" type="fixed">
        <parent link="robot_body"/>
        <child link="front_axis"/>
        <origin xyz="${wheel_base_half} 0 ${-axis_height}" rpy="${pi/2} 0 0"/>
    </joint>

    <joint name="axis_joint_rear" type="fixed">
        <parent link="robot_body"/>
        <child link="rear_axis"/>
        <origin xyz="${-wheel_base_half} 0 ${-axis_height}" rpy="${pi/2} 0 0"/>
    </joint>

    <!-- ========================================= -->
    <!-- Wheels (macro) -->
    <!-- ========================================= -->
    
    <xacro:macro name="wheel" params="name parent side">
        <!-- side: 1 for right wheel, -1 for left wheel -->
        <link name="${name}_wheel">
            <visual>
                <geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry>
                <material name="black"/>
            </visual>
            <collision>
                <geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry>
            </collision>
            <xacro:inertial_cylinder mass="${wheel_mass}" length="${wheel_width}" radius="${wheel_radius}">
                <origin xyz="0 0 0" rpy="0 0 0"/>
            </xacro:inertial_cylinder>
        </link>
        <gazebo reference="${name}_wheel">
            <material>Gazebo/Black</material>
        </gazebo>
        
        <joint name="${name}_wheel_joint" type="continuous">
            <parent link="${parent}_axis"/>
            <child link="${name}_wheel"/>
            <origin xyz="0 0 ${side * (body_width/2 + wheel_width/2 + 0.005)}" rpy="0 0 0"/>
            <axis xyz="0 0 1"/>
        </joint>
    </xacro:macro>

    <!-- 4 wheels -->
    <xacro:wheel name="front_right" parent="front" side="1"/>
    <xacro:wheel name="front_left" parent="front" side="-1"/>
    <xacro:wheel name="rear_right" parent="rear" side="1"/>
    <xacro:wheel name="rear_left" parent="rear" side="-1"/>

  <!-- ========================================= -->
    <!-- servo and camera (rotates) -->
    <!-- ========================================= -->
    
    <!-- servo lin -->
    <link name="camera_servo">
        <visual>
            <geometry><box size="${servo_size} ${servo_size} ${servo_size}"/></geometry>
            <material name="grey"/>
        </visual>
        <collision>
            <geometry><box size="${servo_size} ${servo_size} ${servo_size}"/></geometry>
        </collision>
        <xacro:inertial_box mass="0.05" x="${servo_size}" y="${servo_size}" z="${servo_size}">
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </xacro:inertial_box>
    </link>
    <gazebo reference="camera_servo">
        <material>Gazebo/Grey</material>
    </gazebo>

    <!-- servo joint -->
    <joint name="servo_mount_joint" type="fixed">
        <parent link="robot_body"/>
        <child link="camera_servo"/>
        <origin xyz="${body_length/2 - servo_size} 0 ${body_height/2 + servo_size/2}" rpy="0 0 0"/>
    </joint>

    <!-- camera -->
    <link name="camera_link">
        <visual>
            <geometry><box size="${camera_size_x} ${camera_size_y} ${camera_size_z}"/></geometry>
            <material name="black"/>
        </visual>
        <collision>
            <geometry><box size="${camera_size_x} ${camera_size_y} ${camera_size_z}"/></geometry>
        </collision>
        <xacro:inertial_box mass="${camera_mass}" x="${camera_size_x}" y="${camera_size_y}" z="${camera_size_z}">
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </xacro:inertial_box>
    </link>
    <gazebo reference="camera_link">
        <material>Gazebo/Black</material>
    </gazebo>

    <!-- camera joint: turns left-right (around Z axis) -->
    <!-- 0° = forward, -90° = left, +90° = right -->
    <joint name="camera_pan_joint" type="revolute">
        <parent link="camera_servo"/>
        <child link="camera_link"/>
        <origin xyz="0 0 ${servo_size/2}" rpy="0 0 0"/>
        <axis xyz="0 0 1"/>  <!-- Turn around Z axis (left-right) -->
        <limit lower="${camera_pan_min}" upper="${camera_pan_max}" effort="2.0" velocity="5.0"/>
        <dynamics damping="0.5" friction="0.1"/>
    </joint>

    <!-- Gazebo Camera Plugin -->
    <gazebo reference="camera_link">
    <sensor type="camera" name="camera_sensor">
        <update_rate>30.0</update_rate>
        <camera name="camera">
        <visualize>true</visualize>
            <horizontal_fov>1.047</horizontal_fov>  <!-- 60 degrees -->
            <image>
                <width>640</width>
                <height>480</height>
                <format>R8G8B8</format>
            </image>
            <clip>
                <near>0.05</near>
                <far>100</far>
            </clip>
        </camera>
       <plugin name="camera_controller" filename="libgazebo_ros_camera.so">
            <ros>
                <remapping>~/image:=/camera/image_raw</remapping>
            </ros>
            <frame_name>camera_link</frame_name>
    </plugin>   
    </sensor>
</gazebo>
<gazebo reference="front_left_wheel">
    <mu1>0.3</mu1>
    <mu2>0.3</mu2>
    <fdir1>1 0 0</fdir1>
</gazebo>

<gazebo reference="front_right_wheel">
    <mu1>0.3</mu1>
    <mu2>0.3</mu2>
    <fdir1>1 0 0</fdir1>
</gazebo>

<gazebo reference="rear_left_wheel">
    <mu1>0.3</mu1>
    <mu2>0.3</mu2>
    <fdir1>1 0 0</fdir1>
</gazebo>

<gazebo reference="rear_right_wheel">
    <mu1>0.3</mu1>
    <mu2>0.3</mu2>
    <fdir1>1 0 0</fdir1>
</gazebo>
<!-- ultrasonic (functional) -->
<gazebo reference="ultrasonic_sensor">
    <material>Gazebo/Blue</material>
    <sensor type="ray" name="ultrasonic">
        <always_on>true</always_on>
        <visualize>true</visualize>
        <update_rate>10</update_rate>
        <ray>
            <scan>
                <horizontal>
                    <samples>1</samples>
                    <resolution>1</resolution>
                    <min_angle>0</min_angle>
                    <max_angle>0</max_angle>
                </horizontal>
            </scan>
            <range>
                <min>0.02</min>
                <max>4.0</max>
                <resolution>0.01</resolution>
            </range>
        </ray>
        <plugin name="ultrasonic_controller" filename="libgazebo_ros_ray_sensor.so">
            <ros>
                <namespace>/</namespace>
                <remapping>~/out:=/ultrasonic</remapping>
            </ros>
            <output_type>sensor_msgs/Range</output_type>
            <frame_name>ultrasonic_sensor</frame_name>
        </plugin>
    </sensor>
</gazebo>

</robot>
